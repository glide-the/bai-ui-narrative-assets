{
  "name": "nationality-pwa-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run --exclude \"**/*.integration.test.ts\"",
    "test:coverage": "vitest run --coverage --exclude \"**/*.integration.test.ts\"",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:all": "pnpm test:run && pnpm test:e2e",
    "narrative:generate-assets": "node scripts/narrative-generate-assets.mjs",
    "db:generate": "drizzle-kit generate --config=./drizzle.config.ts",
    "db:preflight": "node scripts/verify-postgres.mjs",
    "db:migrate": "node scripts/verify-postgres.mjs && drizzle-kit push --config=./drizzle.config.ts",
    "db:up": "docker compose up -d postgres",
    "docker:build": "cd docker && docker compose build",
    "docker:up": "cd docker && docker compose up -d --build",
    "docker:down": "cd docker && docker compose down",
    "docker:logs": "cd docker && docker compose logs -f nationality-app"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.64",
    "@anthropic-ai/claude-agent-sdk": "^0.2.20",
    "@aws-sdk/client-s3": "^3.981.0",
    "@aws-sdk/s3-request-presigner": "^3.981.0",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/blob": "^2.0.1",
    "ai": "^6.0.62",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "pg": "^8.13.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tar": "^7.5.7",
    "unzipper": "^0.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "8.4.39",
    "tailwindcss": "4.1.18",
    "typescript": "5.5.4",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  }
}
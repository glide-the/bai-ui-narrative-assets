# ============================================
# ai4sales-pwa-app Docker Environment
# ============================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# ============================================

# ---- Anthropic / Claude Agent ----
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ---- Exa Search ----
EXA_API_KEY=

# ---- Agent Settings ----
MAX_BUDGET_USD=0.5
MAX_TURNS=10
# In Docker, keep this as an in-container path that is volume-mounted.
AGENT_CWD=/app/agent-workspaces

# ---- PostgreSQL ----
POSTGRES_USER=ai4sales
POSTGRES_PASSWORD=ai4sales
POSTGRES_DB=ai4sales
DATABASE_URL=postgres://ai4sales:ai4sales@postgres:5432/ai4sales

# ---- File Storage (S3 / MinIO) ----
FILE_STORAGE_TYPE=s3
FILE_STORAGE_PREFIX=uploads
FILE_STORAGE_S3_BUCKET=vibesales
FILE_STORAGE_S3_REGION=us-east-1
# In Docker Compose, MinIO is accessible at service name "minio"
FILE_STORAGE_S3_ENDPOINT=http://minio:9000
FILE_STORAGE_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
FILE_STORAGE_PREFIX=uploads

# ---- MinIO ----
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# ---- WeKnora Knowledge Base ----
WEKNORA_API_KEY=
WEKNORA_BASE_URL=https://weknora.fanmikeji.cn
WEKNORA_KNOWLEDGE_BASE_ID=

# ---- App Port (host mapping) ----
APP_PORT=3000

# Anthropic API Key for Claude Agent SDK
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# Exa API Key for Exa MCP Server
# Get your API key from: https://exa.ai/
EXA_API_KEY=

# Optional: Cost control settings
# Maximum budget in USD per customer research query (default: 0.5)
MAX_BUDGET_USD=0.5

# Optional: Maximum number of conversation turns (default: 10)
MAX_TURNS=10

# Optional: Agent workspace root directory
# When set, agent sessions create workspace directories under this path.
# If not set, defaults to OS temp directory (e.g., /tmp/claude-agent-workspaces).
# Supports absolute or relative paths (relative to project root).
AGENT_CWD=

# Postgres
# Either set DATABASE_URL or PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai4sales
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ai4sales

# ============================================
# File Storage Configuration
# ============================================

# Storage driver type: 'vercel-blob' (default) or 's3'
FILE_STORAGE_TYPE=vercel-blob

# Storage path prefix (default: 'uploads')
FILE_STORAGE_PREFIX=uploads

# --- Vercel Blob Configuration ---
# Required when FILE_STORAGE_TYPE=vercel-blob
# Get token from Vercel Dashboard > Storage > Blob Store
BLOB_READ_WRITE_TOKEN=

# --- S3 Configuration ---
# Required when FILE_STORAGE_TYPE=s3
FILE_STORAGE_S3_BUCKET=
FILE_STORAGE_S3_REGION=us-east-1

# Optional S3 settings
# AWS_REGION can be used as fallback for FILE_STORAGE_S3_REGION
AWS_REGION=

# Custom endpoint for S3-compatible storage (MinIO, DigitalOcean Spaces, etc.)
FILE_STORAGE_S3_ENDPOINT=

# Use path-style URLs instead of virtual-hosted style (required for MinIO)
FILE_STORAGE_S3_FORCE_PATH_STYLE=

# Custom public base URL for uploaded files (CDN URL)
FILE_STORAGE_S3_PUBLIC_BASE_URL=

# --- Example: MinIO Local Development ---
# Uncomment these lines to use MinIO with docker-compose.yml:
# FILE_STORAGE_TYPE=s3
# FILE_STORAGE_S3_BUCKET=vibesales
# FILE_STORAGE_S3_REGION=us-east-1
# FILE_STORAGE_S3_ENDPOINT=http://localhost:9000
# FILE_STORAGE_S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# WeKnora Knowledge Base Service
# For document processing and knowledge retrieval
WEKNORA_API_KEY=
WEKNORA_BASE_URL=https://weknora.fanmikeji.cn
WEKNORA_KNOWLEDGE_BASE_ID=kb-00000001